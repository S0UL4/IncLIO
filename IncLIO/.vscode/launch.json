{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug run_bag",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/run_bag",
            "args": [
                "dataset/ros2_output",
                "/home/soula/Desktop/PROJECTS/SLAMS/IncLIO/config/velodyne_test.yaml",
                // "--imu-topic", "/imu_raw",
                // "--lidar-topic", "/points_raw",
                "--imu-coefficient", "1.0",
                "--output", "trajectory.txt"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        }
    ]
}
